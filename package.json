{
  "name": "avalon-workspace",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "common",
    "client",
    "server",
    "firebase/functions"
  ],
  "bin": {
    "avalon-admin": "./server/admin.js",
    "avalon-server": "./server/server.js"
  },
  "scripts": {
    "build": "yarn workspace @avalon/client build",
    "bundle:server": "esbuild server/server.js --bundle --platform=node --target=node20 --outfile=dist-server/server.js --define:__BUNDLED__=true",
    "start": "yarn workspace @avalon/server start",
    "admin": "avalon-admin",
    "test": "node test-flow-v5.mjs",
    "test:browser": "node test-browser.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^9.29.1",
    "playwright": "1.56.1",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3"
  }
}
