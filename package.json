{
  "name": "avalon-workspace",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "common",
    "client",
    "server"
  ],
  "bin": {
    "avalon-admin": "./server/admin.ts"
  },
  "scripts": {
    "build:common": "yarn workspace @avalon/common build",
    "build": "yarn build:common && yarn workspace @avalon/client build",
    "apply-schema": "node --env-file=.env server/apply-schema.mjs",
    "admin": "tsx --env-file=.env server/admin.ts",
    "test": "node tests/e2e-flow.mjs",
    "test:browser": "node tests/e2e-browser.mjs",
    "test:game": "node tests/e2e-full-game.mjs"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vue-eslint-parser": "^10.4.0"
  }
}
