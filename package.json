{
  "name": "avalon-workspace",
  "packageManager": "yarn@4.17.0",
  "workspaces": [
    "common",
    "client",
    "server",
    "firebase/functions"
  ],
  "bin": {
    "avalon-admin": "./server/admin.ts",
    "avalon-server": "./server/server.ts"
  },
  "scripts": {
    "build:common": "yarn workspace @avalon/common build",
    "build": "yarn build:common && yarn workspace @avalon/client build",
    "bundle:server": "yarn build:common && esbuild server/server.ts --bundle --platform=node --target=node24 --outfile=dist-server/server.js --format=esm --define:__BUNDLED__=true --banner:js=\"import{createRequire}from'module';import{fileURLToPath as _f}from'url';import{dirname as _d}from'path';const require=createRequire(import.meta.url);const __filename=_f(import.meta.url);const __dirname=_d(__filename);\"",
    "start": "yarn workspace @avalon/server start",
    "admin": "yarn workspace @avalon/server tsx admin.ts",
    "test": "node tests/e2e-flow.mjs",
    "test:browser": "node tests/e2e-browser.mjs",
    "test:game": "node tests/e2e-full-game.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "autoprefixer": "^10.5.4",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "postcss": "^8.5.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vue-eslint-parser": "^10.4.1"
  },
  "resolutions": {
    "basic-ftp": "^6.0.1",
    "brace-expansion@^1.1.7": "^1.1.13",
    "fast-xml-parser": "^5.10.1",
    "flatted": "^3.4.2",
    "hono": "^4.12.31",
    "@hono/node-server": "^2.0.10",
    "node-forge": "^1.4.0",
    "picomatch@^2.0.4": "^2.3.2",
    "picomatch@^2.2.1": "^2.3.2",
    "yaml": "^2.9.0"
  }
}
