service cloud.firestore {
  
  match /databases/{database}/documents {
  	match /logs/{log} {
    	// get only: listing would expose every game log (incl. player uids)
    	allow get;
    }
    
    match /users/{uid} {
    	allow read: if request.auth.uid == uid;
    }
    
    match /lobbies/{lobby}/roles/{uid} {
    	allow read: if request.auth.uid == uid;    
    }
    
    match /lobbies/{lobby} {
    	// get only: listing would let anyone enumerate live lobby join codes
    	allow get;
    }
    
    match /stats/{stat} {
    	allow read;
    }
  }
}
