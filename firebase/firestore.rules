service cloud.firestore {
  
  match /databases/{database}/documents {
  	match /logs/{log} {
    	// get only: listing would expose every game log (incl. player uids);
    	// auth required since log ids (timestamp + lobby code) are guessable
    	allow get: if request.auth != null;
    }
    
    match /users/{uid} {
    	allow read: if request.auth.uid == uid;
    }
    
    match /lobbies/{lobby}/roles/{uid} {
    	allow read: if request.auth.uid == uid;    
    }
    
    match /lobbies/{lobby} {
    	// get only: listing would let anyone enumerate live lobby join codes;
    	// auth required since 3-letter codes are small enough to brute force
    	allow get: if request.auth != null;
    }
    
    match /stats/{stat} {
    	allow read;
    }
  }
}
